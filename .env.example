# .env.example - Environment Variables Template

# EmailJS Configuration (for contact form)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxxxxxxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxxxxxxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Optional: GitHub API (for live stats)
VITE_GITHUB_USERNAME=your_username
VITE_GITHUB_TOKEN=your_github_token

# Application
VITE_APP_TITLE=Ramalakshmi - AI Engineer Portfolio
VITE_APP_URL=https://your-domain.com

# Notes:
# 1. Copy this file to .env and fill in your values
# 2. Never commit .env file to git
# 3. Add .env to .gitignore
# 4. Use VITE_ prefix for frontend variables
# 5. Access in code: import.meta.env.VITE_YOUR_VAR
